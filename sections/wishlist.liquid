{%- comment -%}
  Wishlist page — reads product handles from localStorage ('leon_wishlist'),
  fetches each product via /products/{handle}.js, and renders cards.
{%- endcomment -%}

<div class="wishlist-page">
  <div class="wishlist-page__header">
    <h1 class="wishlist-page__title">Wishlist</h1>
    <span class="wishlist-page__count" data-wishlist-count>0 items</span>
  </div>

  <div class="wishlist-page__empty" data-wishlist-empty hidden>
    <svg class="wishlist-page__empty-icon" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    </svg>
    <h2 class="wishlist-page__empty-title">Your wishlist is empty</h2>
    <p class="wishlist-page__empty-desc">Save the pieces you love by tapping the heart on any product. They'll show up here so you can come back to them anytime.</p>
    <a href="/collections/all" class="wishlist-page__empty-button">Shop all products</a>
  </div>

  <div class="wishlist-page__loading" data-wishlist-loading hidden>
    Loading…
  </div>

  <div class="wishlist-page__grid" data-wishlist-grid hidden></div>
</div>

{% stylesheet %}
  .wishlist-page {
    padding: 32px 0 64px;
  }

  .wishlist-page [hidden] {
    display: none !important;
  }

  .wishlist-page__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 12px;
    border-bottom: 1px solid #e5e5e5;
    margin-bottom: 24px;
  }

  .wishlist-page__title {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0;
  }

  .wishlist-page__count {
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  .wishlist-page__empty,
  .wishlist-page__loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 96px 24px;
    text-align: center;
  }

  .wishlist-page__loading {
    font-size: 13px;
    opacity: 0.6;
  }

  .wishlist-page__empty-icon {
    color: var(--color-foreground);
    opacity: 0.35;
    margin-bottom: 8px;
  }

  .wishlist-page__empty-title {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0;
  }

  .wishlist-page__empty-desc {
    font-size: 13px;
    line-height: 1.6;
    max-width: 420px;
    opacity: 0.65;
    margin: 0;
  }

  .wishlist-page__empty-button {
    margin-top: 12px;
    display: inline-block;
    padding: 12px 32px;
    background: var(--color-foreground);
    color: var(--color-background);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .wishlist-page__empty-button:hover {
    opacity: 0.85;
  }

  .wishlist-page__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .wishlist-page__card {
    position: relative;
    background: #f7f7f7;
  }

  .wishlist-page__card-link {
    display: block;
    text-decoration: none;
    color: var(--color-foreground);
  }

  .wishlist-page__img-wrap {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f0f0f0;
  }

  .wishlist-page__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .wishlist-page__card:hover .wishlist-page__img {
    transform: scale(1.03);
  }

  .wishlist-page__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 12px 16px 24px;
  }

  .wishlist-page__vendor {
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .wishlist-page__name {
    font-size: 13px;
  }

  .wishlist-page__price {
    font-size: 13px;
    font-weight: 600;
    margin-top: 4px;
  }

  .wishlist-page__price-compare {
    opacity: 0.5;
    font-weight: 400;
    margin-right: 8px;
    text-decoration: line-through;
  }

  /* Action buttons — match collection card style */
  .wishlist-page__action {
    position: absolute;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(4px);
    border: none;
    cursor: pointer;
    color: var(--color-foreground);
    padding: 0;
    transition: background 0.2s, color 0.2s;
    z-index: 2;
  }

  .wishlist-page__action:hover {
    background: #000;
    color: #fff;
  }

  .wishlist-page__action--wishlist {
    top: 10px;
    right: 10px;
    background: #000;
    color: #fff;
  }

  .wishlist-page__action--wishlist svg {
    fill: currentColor;
  }

  .wishlist-page__action--cart {
    bottom: 10px;
    left: 10px;
  }

  /* Toast */
  .leon-toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: #000;
    color: #fff;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 12px 24px;
    z-index: 10000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .leon-toast.is-visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 1024px) {
    .wishlist-page__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .wishlist-page__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var KEY = 'leon_wishlist';
    var root = document.querySelector('.wishlist-page');
    if (!root) return;

    var grid = root.querySelector('[data-wishlist-grid]');
    var empty = root.querySelector('[data-wishlist-empty]');
    var loading = root.querySelector('[data-wishlist-loading]');
    var count = root.querySelector('[data-wishlist-count]');

    function show(el) { el.hidden = false; }
    function hide(el) { el.hidden = true; }

    function readHandles() {
      try { return JSON.parse(localStorage.getItem(KEY) || '[]'); }
      catch (e) { return []; }
    }

    function writeHandles(list) {
      try { localStorage.setItem(KEY, JSON.stringify(list)); } catch (e) {}
    }

    function formatMoney(cents) {
      return '$ ' + (cents / 100).toFixed(2);
    }

    /* Toast */
    var toastEl = null, toastTimer = null;
    function showToast(msg) {
      if (!toastEl) {
        toastEl = document.createElement('div');
        toastEl.className = 'leon-toast';
        document.body.appendChild(toastEl);
      }
      toastEl.textContent = msg;
      requestAnimationFrame(function () { toastEl.classList.add('is-visible'); });
      clearTimeout(toastTimer);
      toastTimer = setTimeout(function () {
        toastEl.classList.remove('is-visible');
      }, 2200);
    }

    function removeHandle(handle, title) {
      var list = readHandles().filter(function (h) { return h !== handle; });
      writeHandles(list);
      var card = grid.querySelector('[data-handle="' + handle + '"]');
      if (card) card.remove();
      var remaining = grid.querySelectorAll('.wishlist-page__card').length;
      count.textContent = remaining + (remaining === 1 ? ' item' : ' items');
      if (remaining === 0) {
        hide(grid);
        show(empty);
      }
      showToast((title || 'Product') + ' removed from wishlist');
    }

    function addToCart(variantId, title, btn) {
      if (!variantId) return;
      btn.disabled = true;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
      }).then(function (r) { return r.ok ? r.json() : Promise.reject(r); })
        .then(function () {
          showToast((title || 'Product') + ' added to cart');
          document.dispatchEvent(new CustomEvent('cart:updated'));
        })
        .catch(function () { showToast('Could not add to cart'); })
        .finally(function () { btn.disabled = false; });
    }

    function render(products) {
      hide(loading);
      if (products.length === 0) {
        show(empty);
        hide(grid);
        count.textContent = '0 items';
        return;
      }
      hide(empty);
      show(grid);
      count.textContent = products.length + (products.length === 1 ? ' item' : ' items');

      grid.innerHTML = products.map(function (p) {
        var img = p.featured_image
          ? '<img src="' + p.featured_image + '" alt="' + (p.title || '') + '" loading="lazy" class="wishlist-page__img">'
          : '';
        var vendor = p.vendor ? '<span class="wishlist-page__vendor">' + p.vendor + '</span>' : '';
        var compare = (p.compare_at_price && p.compare_at_price > p.price)
          ? '<span class="wishlist-page__price-compare">' + formatMoney(p.compare_at_price) + '</span>'
          : '';
        var variantId = (p.variants && p.variants[0] && p.variants[0].id) || '';
        return (
          '<div class="wishlist-page__card" data-handle="' + p.handle + '" data-title="' + (p.title || '').replace(/"/g, '&quot;') + '" data-variant="' + variantId + '">' +
            '<a href="' + p.url + '" class="wishlist-page__card-link">' +
              '<div class="wishlist-page__img-wrap">' +
                img +
                '<button type="button" class="wishlist-page__action wishlist-page__action--wishlist" data-remove aria-label="Remove from wishlist">' +
                  '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
                    '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>' +
                  '</svg>' +
                '</button>' +
                '<button type="button" class="wishlist-page__action wishlist-page__action--cart" data-add-cart aria-label="Add to cart">' +
                  '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
                    '<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>' +
                    '<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>' +
                  '</svg>' +
                '</button>' +
              '</div>' +
              '<div class="wishlist-page__info">' +
                vendor +
                '<span class="wishlist-page__name">' + p.title + '</span>' +
                '<span class="wishlist-page__price">' + compare + formatMoney(p.price) + '</span>' +
              '</div>' +
            '</a>' +
          '</div>'
        );
      }).join('');

      grid.querySelectorAll('[data-remove]').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          var card = btn.closest('.wishlist-page__card');
          removeHandle(card.getAttribute('data-handle'), card.getAttribute('data-title'));
        });
      });

      grid.querySelectorAll('[data-add-cart]').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          var card = btn.closest('.wishlist-page__card');
          addToCart(card.getAttribute('data-variant'), card.getAttribute('data-title'), btn);
        });
      });
    }

    function load() {
      var handles = readHandles();
      if (handles.length === 0) {
        render([]);
        return;
      }
      show(loading);
      hide(grid);
      hide(empty);

      Promise.all(handles.map(function (h) {
        return fetch('/products/' + h + '.js')
          .then(function (r) { return r.ok ? r.json() : null; })
          .catch(function () { return null; });
      })).then(function (results) {
        var valid = results.filter(function (p) { return p; });
        var validHandles = valid.map(function (p) { return p.handle; });
        if (validHandles.length !== handles.length) writeHandles(validHandles);
        render(valid);
      });
    }

    load();
  })();
</script>

{% schema %}
{
  "name": "Wishlist",
  "settings": []
}
{% endschema %}

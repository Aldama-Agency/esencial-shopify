<div class="dual-image full-width">
  <div class="dual-image__row">
    {% for block in section.blocks %}
      {% if block.type == 'image' %}
        <div class="dual-image__item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="dual-image__link">
          {% endif %}

          <div
            class="dual-image__image-wrapper"
            {% if block.settings.solid_color != blank %}style="background-color: {{ block.settings.solid_color }};"{% endif %}
          >
            {% if block.settings.solid_color != blank %}
              {% comment %} Solid color block — no image rendered {% endcomment %}
            {% elsif block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 1400 }}"
                alt="{{ block.settings.image.alt | escape }}"
                loading="lazy"
                width="700"
                height="933"
                class="dual-image__img"
              >
            {% elsif block.settings.image_url != blank %}
              <img
                src="{{ block.settings.image_url }}"
                alt=""
                loading="lazy"
                class="dual-image__img"
              >
            {% else %}
              <div class="dual-image__placeholder">
                <span>Replace with your image</span>
              </div>
            {% endif %}

            {% if block.settings.caption != blank %}
              <div class="dual-image__caption">{{ block.settings.caption }}</div>
            {% endif %}
          </div>

          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .dual-image {
    width: 100%;
  }

  .dual-image__row {
    display: flex;
    gap: 2px;
  }

  .dual-image__item {
    flex: 0 0 calc(50% - 1px);
    position: relative;
    overflow: hidden;
  }

  .dual-image__link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .dual-image__image-wrapper {
    width: 100%;
    height: 80dvh;
    overflow: hidden;
    position: relative;
    background-color: #e5e5e5;
  }

  .dual-image__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .dual-image__item:hover .dual-image__img {
    transform: scale(1.03);
  }

  .dual-image__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
  }

  .dual-image__placeholder span {
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
    border: 1px dashed #ccc;
    padding: 12px 20px;
  }

  .dual-image__caption {
    position: absolute;
    bottom: 20px;
    left: 20px;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: white;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }

  @media (max-width: 768px) {
    .dual-image__row {
      flex-direction: column;
      gap: 2px;
    }

    .dual-image__item {
      flex: 0 0 100%;
    }

    .dual-image__image-wrapper {
      height: 60dvh;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Dual Image",
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Or external image URL"
        },
        {
          "type": "color",
          "id": "solid_color",
          "label": "Or solid color (overrides image)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (optional)"
        }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Dual Image",
      "blocks": [
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}

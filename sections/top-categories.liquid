{%- comment -%}
  Top categories strip — 60px-high bar under the header with text-only
  links to the top categories, centered.
{%- endcomment -%}

<nav class="top-categories" aria-label="Top categories">
  <div class="top-categories__row">
    {% for block in section.blocks %}
      {%- assign col = collections[block.settings.collection] -%}
      {%- assign label = block.settings.label | default: col.title -%}
      <a
        href="{{ col.url | default: '/collections/all' }}"
        class="top-categories__link"
        {{ block.shopify_attributes }}
      >{{ label }}</a>
    {% endfor %}
  </div>
</nav>

{% stylesheet %}
  .top-categories {
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid #e5e5e5;
    background: var(--color-background);
    overflow: hidden;
  }

  .top-categories__row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    width: 100%;
    max-width: 100%;
    padding: 0 var(--page-margin, 24px);
    flex-wrap: nowrap;
  }

  .top-categories__link {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-foreground);
    white-space: nowrap;
    position: relative;
    padding: 6px 0;
    transition: opacity 0.2s ease;
  }

  .top-categories__link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s ease;
  }

  .top-categories__link:hover::after {
    transform: scaleX(1);
  }

  @media (max-width: 900px) {
    .top-categories__row {
      overflow-x: auto;
      justify-content: flex-start;
      gap: 24px;
      scrollbar-width: none;
    }
    .top-categories__row::-webkit-scrollbar {
      display: none;
    }
    .top-categories__link {
      font-size: 11px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Top Categories",
  "max_blocks": 12,
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Custom label (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Top Categories",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}

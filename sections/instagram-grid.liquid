<div class="instagram-grid full-width">
  <div class="instagram-grid__header">
    {% if section.settings.heading != blank %}
      <span class="instagram-grid__heading">{{ section.settings.heading | upcase }}</span>
    {% endif %}
    {% if section.settings.instagram_url != blank %}
      <a
        href="{{ section.settings.instagram_url }}"
        class="instagram-grid__handle"
        target="_blank"
        rel="noopener noreferrer"
      >
        {{ section.settings.instagram_handle | default: '@leonmoda' }}
      </a>
    {% endif %}
  </div>

  <div class="instagram-grid__grid">
    {% for block in section.blocks %}
      {% if block.type == 'post' %}
        <div class="instagram-grid__item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a
              href="{{ block.settings.link }}"
              target="_blank"
              rel="noopener noreferrer"
              class="instagram-grid__link"
            >
          {% endif %}

          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 500, height: 500, crop: 'center' }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="500"
              height="500"
              class="instagram-grid__img"
            >
          {% elsif block.settings.image_url != blank %}
            <img
              src="{{ block.settings.image_url }}"
              alt=""
              loading="lazy"
              class="instagram-grid__img"
            >
          {% else %}
            <div class="instagram-grid__placeholder">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="2" width="24" height="24" rx="6" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <circle cx="14" cy="14" r="5" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <circle cx="21" cy="7" r="1.5" fill="currentColor"/>
              </svg>
              <span>Add image</span>
            </div>
          {% endif %}

          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .instagram-grid {
    width: 100%;
    padding-top: 48px;
  }

  .instagram-grid__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--page-margin) 24px;
  }

  .instagram-grid__heading {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .instagram-grid__handle {
    font-size: 13px;
    letter-spacing: 0.08em;
    color: var(--color-foreground);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .instagram-grid__handle:hover {
    opacity: 1;
  }

  .instagram-grid__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 8px;
    padding: 0 8px 8px;
  }

  .instagram-grid__item {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    position: relative;
    background-color: #f0f0f0;
  }

  .instagram-grid__link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .instagram-grid__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .instagram-grid__item:hover .instagram-grid__img {
    transform: scale(1.05);
  }

  .instagram-grid__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #bbb;
  }

  .instagram-grid__placeholder span {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .instagram-grid__grid {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .instagram-grid__grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(4, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Instagram Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow us on Instagram"
    },
    {
      "type": "text",
      "id": "instagram_handle",
      "label": "Instagram handle",
      "default": "@leonmoda"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram profile URL"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Post image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Or external image URL"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Post link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Instagram Grid",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}

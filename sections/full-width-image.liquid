<div class="full-width-image full-width">
  {% if section.settings.link != blank %}
    <a href="{{ section.settings.link }}" class="full-width-image__link">
  {% endif %}

  {% if section.settings.image != blank %}
    <img
      src="{{ section.settings.image | image_url: width: 2400 }}"
      alt="{{ section.settings.image.alt | escape }}"
      loading="lazy"
      width="2400"
      height="1350"
      class="full-width-image__img"
    >
  {% elsif section.settings.image_url != blank %}
    <img
      src="{{ section.settings.image_url }}"
      alt=""
      loading="lazy"
      class="full-width-image__img"
    >
  {% else %}
    <div class="full-width-image__placeholder">
      <span>Replace with your image</span>
    </div>
  {% endif %}

  {% if section.settings.overlay_text != blank %}
    <div class="full-width-image__overlay">
      <p class="full-width-image__overlay-text">{{ section.settings.overlay_text }}</p>
      {% if section.settings.overlay_link_text != blank and section.settings.link != blank %}
        <span class="full-width-image__overlay-cta">{{ section.settings.overlay_link_text | upcase }}</span>
      {% endif %}
    </div>
  {% endif %}

  {% if section.settings.link != blank %}
    </a>
  {% endif %}
</div>

{% stylesheet %}
  .full-width-image {
    width: 100%;
    height: 90dvh;
    position: relative;
    overflow: hidden;
    margin-top: 120px;
  }

  .full-width-image__link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .full-width-image__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .full-width-image__placeholder {
    width: 100%;
    height: 100%;
    background-color: #e5e5e5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .full-width-image__placeholder span {
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
    border: 1px dashed #ccc;
    padding: 12px 20px;
  }

  .full-width-image__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
    background: rgba(0, 0, 0, 0.2);
  }

  .full-width-image__overlay-text {
    font-size: clamp(28px, 4vw, 60px);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: white;
    margin: 0;
    text-align: center;
  }

  .full-width-image__overlay-cta {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: white;
    border-bottom: 1px solid white;
    padding-bottom: 2px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Full Width Image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_url",
      "label": "Or external image URL"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "text",
      "id": "overlay_text",
      "label": "Overlay text (optional)"
    },
    {
      "type": "text",
      "id": "overlay_link_text",
      "label": "Overlay CTA text (optional)"
    }
  ],
  "presets": [
    {
      "name": "Full Width Image"
    }
  ]
}
{% endschema %}
